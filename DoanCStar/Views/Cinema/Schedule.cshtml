
@{
    ViewData["Title"] = ViewBag.CinemaName + " - Lịch chiếu";
}

<div class="container py-5">
    <h2 class="text-center mb-5 text-warning fw-bold">
        <i class="bi bi-geo-alt-fill"></i> @ViewBag.CinemaName
    </h2>

    <!-- Tab đẹp -->
    <ul class="nav nav-pills justify-content-center mb-5 gap-4" role="tablist">
        <li class="nav-item">
            <button class="nav-link active fs-5 px-5 py-3 rounded-pill" data-bs-toggle="tab" data-bs-target="#dangchieu">
                PHIM ĐANG CHIẾU
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link fs-5 px-5 py-3 rounded-pill" data-bs-toggle="tab" data-bs-target="#sapchieu">
                PHIM SẮP CHIẾU
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="dangchieu">
            @await Html.PartialAsync("_MovieScheduleGrid", ViewBag.DangChieu as List<Movie>)
        </div>
        <div class="tab-pane fade" id="sapchieu">
            @await Html.PartialAsync("_MovieScheduleGrid", ViewBag.SapChieu as List<Movie>)
        </div>
    </div>
</div>
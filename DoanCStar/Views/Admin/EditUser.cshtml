@model DoanCStar.Models.User

@{
    ViewData["Title"] = "Chỉnh sửa Tài khoản";
    Layout = "_AdminLayout";
}

<h1 class="h3 mb-4">Chỉnh sửa Tài khoản: @Model.FullName</h1>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Thông tin chi tiết</h6>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">

                <form asp-action="EditUser" id="editUserForm">
                    @Html.AntiForgeryToken()


                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input type="hidden" asp-for="UserId" />

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">UserName</label>
                        <input asp-for="FullName" class="form-control" readonly />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">Vai trò (Role)</label>
                        <select asp-for="Role" class="form-select">
                            <option value="Customer">Customer</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreatedAt" class="form-label">Ngày tạo</label>
                        <input asp-for="CreatedAt" class="form-control" readonly />
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle-fill"></i> Lưu thay đổi
                        </button>
                        <a asp-action="UserManagement" class="btn btn-secondary ms-2">
                            <i class="bi bi-x-circle"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* ===== SỬA LẠI TOÀN BỘ SCRIPT AJAX ===== *@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const editForm = document.getElementById("editUserForm");

            const toastElement = document.getElementById('liveToast');
            const toastBody = document.getElementById('toastBodyMessage');
            const bsToast = new bootstrap.Toast(toastElement, {
                delay: 3000 // Tự động tắt sau 3 giây
            });

            if (editForm) {
                editForm.addEventListener("submit", function (e) {
                    e.preventDefault(); // Ngăn form tải lại trang

                    const formData = new FormData(editForm);

                    fetch(editForm.action, {
                        method: "POST",
                        body: formData
                    })
                    .then(response => {
                        if (response.ok) {
                            return response.json(); // Lấy message thành công
                        } else {
                            throw new Error("Lỗi Validation. Form sẽ tự hiển thị.");
                        }
                    })
                    .then(data => {
                        toastBody.textContent = data.message;

                        // Hiển thị toast
                        bsToast.show();
                    })
                    .catch(error => {
                        console.log(error.message);
                    });
                });
            }
        });
    </script>
}
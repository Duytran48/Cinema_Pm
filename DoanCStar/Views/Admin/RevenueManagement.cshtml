@model DoanCStar.ViewModels.RevenueReportViewModel

@{
    ViewData["Title"] = "Báo cáo Doanh thu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-4">
    <h2 class="text-primary fw-bold mb-4"><i class="bi bi-bar-chart-line-fill"></i> BÁO CÁO DOANH THU</h2>

    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-body bg-light">
            <form method="get" asp-action="RevenueManagement" class="row align-items-end g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Từ ngày:</label>
                    <input type="date" name="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Đến ngày:</label>
                    <input type="date" name="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">
                        <i class="bi bi-filter"></i> Xem báo cáo
                    </button>
                </div>
                <div class="col-md-4 text-end">
                    <div class="p-2 rounded bg-white border border-success">
                        <small class="text-muted text-uppercase fw-bold">Tổng doanh thu hệ thống</small>
                        <h3 class="text-success fw-bold m-0">@Model.TotalSystemRevenue.ToString("N0") VNĐ</h3>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="m-0"><i class="bi bi-film"></i> Doanh thu theo Phim</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 text-center align-middle">
                            <thead class="table-secondary">
                                <tr>
                                    <th class="text-start">Tên Phim</th>
                                    <th>Vé bán</th>
                                    <th class="text-end">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RevenueByMovie.Any())
                                {
                                    foreach (var item in Model.RevenueByMovie)
                                    {
                                        <tr>
                                            <td class="text-start fw-bold">@item.MovieTitle</td>
                                            <td><span class="badge bg-secondary">@item.TicketCount</span></td>
                                            <td class="text-end text-success fw-bold">@item.TotalRevenue.ToString("N0")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="py-4 text-muted">Không có dữ liệu</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-warning text-dark">
                    <h5 class="m-0"><i class="bi bi-building"></i> Doanh thu theo Rạp</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 text-center align-middle">
                            <thead class="table-secondary">
                                <tr>
                                    <th class="text-start">Tên Rạp</th>
                                    <th>Vé bán</th>
                                    <th class="text-end">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RevenueByCinema.Any())
                                {
                                    foreach (var item in Model.RevenueByCinema)
                                    {
                                        <tr>
                                            <td class="text-start fw-bold">@item.CinemaName</td>
                                            <td><span class="badge bg-secondary">@item.TicketCount</span></td>
                                            <td class="text-end text-success fw-bold">@item.TotalRevenue.ToString("N0")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="py-4 text-muted">Không có dữ liệu</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@model DoanCStar.Models.Cinema

@{
    ViewData["Title"] = "Thêm Rạp Mới";
    Layout = "_AdminLayout";
}

<h1 class="h3 mb-4 text-gray-800">Thêm Rạp Mới</h1>

<div class="card shadow mb-4">
    <div class="card-body">
        <form asp-action="CreateCinema">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label">Tên Rạp *</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="City" class="form-label">Thành phố *</label>
                    <select asp-for="City" asp-items="ViewBag.Cities" class="form-select">
                        <option value="">-- Chọn Thành phố --</option>
                    </select>
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label">Địa chỉ *</label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label">Số điện thoại</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>


            <div class="mt-4">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle-fill me-2"></i> Lưu Rạp
                </button>
                <a asp-action="CinemaManagement" class="btn btn-secondary ms-2">
                    <i class="bi bi-x-circle me-2"></i> Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
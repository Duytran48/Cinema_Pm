@model DoanCStar.Models.Room

@{
    ViewData["Title"] = "Xác nhận Xóa Phòng";
    Layout = "_AdminLayout";
    int cinemaId = Model.CinemaId;
    string cinemaName = Model.Cinema?.Name ?? "Không rõ";
}

<h1 class="h3 mb-4 text-gray-800">Xác nhận Xóa Phòng</h1>

<div class="alert alert-danger" role="alert">
    <strong>Bạn có chắc chắn muốn xóa phòng "@Model.Name" thuộc rạp "@cinemaName" không?</strong>
    <p>Tất cả ghế ngồi và suất chiếu thuộc phòng này cũng có thể bị ảnh hưởng hoặc xóa theo. Hành động này không thể hoàn tác.</p>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Thông tin Phòng sẽ bị xóa</h6>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Tên Phòng</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Sức chứa</dt>
            <dd class="col-sm-9">@Model.Capacity</dd>

            <dt class="col-sm-3">Thuộc Rạp</dt>
            <dd class="col-sm-9">@cinemaName</dd>
        </dl>

        <form asp-action="DeleteRoom">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="RoomId" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash3-fill me-2"></i> Xác nhận Xóa
            </button>
            <a asp-action="RoomManagement" asp-route-cinemaId="@cinemaId" class="btn btn-secondary ms-2">
                <i class="bi bi-x-circle me-2"></i> Hủy
            </a>
        </form>
    </div>
</div>
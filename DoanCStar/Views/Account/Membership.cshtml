@model DoanCStar.Models.User

@{
    ViewData["Title"] = "Hạng thành viên";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // === 1. LOGIC TÍNH TOÁN HẠNG & ĐIỂM ===
    var points = Model.Points;

    // Cấu hình hạng
    string currentRank = "Thành viên Đồng";
    string rankColorClass = "secondary";
    string cardGradient = "linear-gradient(45deg, #6c757d, #adb5bd)"; // Gradient Đồng
    string rankIcon = "bi-award";

    // Mốc tiếp theo
    string nextRankName = "Bạc";
    int nextRankPoints = 500; // <--- Đã sửa tên biến thống nhất
    int currentRankMin = 0;

    if (points >= 2000)
    {
        currentRank = "Thành viên Vàng";
        rankColorClass = "warning";
        cardGradient = "linear-gradient(45deg, #ffd700, #fdb931)";
        rankIcon = "bi-trophy-fill";
        nextRankName = "MAX";
        nextRankPoints = 2000;
        currentRankMin = 2000;
    }
    else if (points >= 500)
    {
        currentRank = "Thành viên Bạc";
        rankColorClass = "light";
        cardGradient = "linear-gradient(45deg, #dee2e6, #f8f9fa)";
        rankIcon = "bi-star-half";
        nextRankName = "Vàng";
        nextRankPoints = 2000;
        currentRankMin = 500;
    }

    // Tính % tiến độ
    int progressPercent = 100;
    if (points < 2000 && nextRankPoints > currentRankMin)
    {
        progressPercent = (int)((double)(points - currentRankMin) / (nextRankPoints - currentRankMin) * 100);
    }
}

<style>
    /* CSS Riêng cho trang này */
    .membership-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        overflow: hidden;
    }

    .rank-card-header {
        padding: 2rem;
        color: #fff;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
    }

    .nav-pills .nav-link.active {
        background-color: #ffc107 !important;
        color: #000 !important;
        font-weight: bold;
    }

    .nav-pills .nav-link {
        color: #adb5bd;
        transition: all 0.3s;
    }

        .nav-pills .nav-link:hover {
            color: #fff;
            background-color: rgba(255,255,255,0.1);
        }
</style>

<div class="container py-5">
    <div class="row">

        @* === CỘT TRÁI: MENU ĐIỀU HƯỚNG === *@
        <div class="col-lg-3 mb-4">
            <div class="card bg-dark text-white border-secondary shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-fill fs-1 text-white"></i>
                        </div>
                    </div>
                    <h5 class="card-title fw-bold">@Model.FullName</h5>
                    <p class="card-text text-muted small">@Model.Email</p>

                    <hr class="border-secondary my-3" />

                    <div class="nav flex-column nav-pills text-start">
                        <a class="nav-link mb-2" asp-controller="Account" asp-action="Profile">
                            <i class="bi bi-person-lines-fill me-2"></i> Thông tin cá nhân
                        </a>
                        <a class="nav-link active mb-2" asp-controller="Account" asp-action="Membership">
                            <i class="bi bi-star-fill me-2"></i> Hạng thành viên
                        </a>
                        <a class="nav-link mb-2" asp-controller="Booking" asp-action="History">
                            <i class="bi bi-clock-history me-2"></i> Lịch sử giao dịch
                        </a>
                        <a class="nav-link text-danger mt-2" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @* === CỘT PHẢI: THÔNG TIN HẠNG THÀNH VIÊN === *@
        <div class="col-lg-9">

            @* 1. THẺ HẠNG & ĐIỂM *@
            <div class="membership-card mb-4" style="background: @cardGradient;">
                <div class="rank-card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75" style="color:black; font-weight:bold;">Hạng hiện tại</h6>
                            <h2 class="fw-bold m-0 display-6 text-dark">
                                <i class="bi @rankIcon me-2"></i>@currentRank
                            </h2>
                        </div>
                        <div class="text-end text-dark">
                            <h6 class="text-uppercase mb-1 opacity-75" style="color:black; font-weight:bold;">Điểm tích lũy</h6>
                            <h1 class="fw-bold m-0 display-4">@Model.Points</h1>
                        </div>
                    </div>

                    <div class="mt-4">
                        <div class="d-flex justify-content-between text-dark small fw-bold mb-1">
                            <span>@currentRankMin điểm</span>
                            @if (points < 2000)
                            {
                                <span>Mục tiêu: @nextRankName (@nextRankPoints điểm)</span>
                            }
                            else
                            {
                                <span>Đỉnh cao danh vọng!</span>
                            }
                        </div>
                        <div class="progress" style="height: 12px; background-color: rgba(0,0,0,0.2); border-radius: 10px;">
                            <div class="progress-bar bg-white progress-bar-striped progress-bar-animated"
                                 role="progressbar"
                                 style="width: @progressPercent%;"
                                 aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">
                            </div>
                        </div>
                        @if (points < 2000)
                        {
                            <div class="mt-2 text-dark small">
                                @* Đã sửa biến ở đây *@
                                Bạn cần thêm <strong>@(nextRankPoints - points)</strong> điểm nữa để thăng hạng.
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* 2. QUYỀN LỢI THÀNH VIÊN *@
            <div class="card bg-dark border-0 shadow-sm text-white">
                <div class="card-header bg-transparent border-secondary py-3">
                    <h5 class="m-0 fw-bold text-warning"><i class="bi bi-gift me-2"></i> Quyền lợi của bạn</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0 align-middle text-center">
                            <thead class="table-secondary text-dark">
                                <tr>
                                    <th>Hạng</th>
                                    <th>Mốc điểm</th>
                                    <th>Tích lũy</th>
                                    <th>Ưu đãi đặc biệt</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="@(points < 500 ? "table-active border-warning border-2" : "")">
                                    <td><span class="badge bg-secondary">Đồng</span></td>
                                    <td>0 - 499</td>
                                    <td>5%</td>
                                    <td class="text-muted">-</td>
                                </tr>
                                <tr class="@(points >= 500 && points < 2000 ? "table-active border-warning border-2" : "")">
                                    <td><span class="badge bg-light text-dark">Bạc</span></td>
                                    <td>500 - 1999</td>
                                    <td>7%</td>
                                    <td><i class="bi bi-cake2 text-warning"></i> Quà sinh nhật (1 Vé 2D)</td>
                                </tr>
                                <tr class="@(points >= 2000 ? "table-active border-warning border-2" : "")">
                                    <td><span class="badge bg-warning text-dark">Vàng</span></td>
                                    <td>2000+</td>
                                    <td>10%</td>
                                    <td><i class="bi bi-gift-fill text-warning"></i> 2 Vé + Combo bắp nước</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @* Gợi ý hành động *@
            <div class="mt-4 text-center">
                <p class="text-muted">Tích điểm dễ dàng bằng cách đặt vé xem phim ngay hôm nay!</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-warning fw-bold px-4 py-2 rounded-pill">
                    <i class="bi bi-ticket-perforated me-2"></i> Đặt vé ngay
                </a>
            </div>

        </div>
    </div>
</div>
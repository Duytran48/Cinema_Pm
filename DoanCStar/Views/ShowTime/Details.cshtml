@model DoanCStar.ViewModels.ShowTimeViewModel
@{
    ViewData["Title"] = "Chi tiết suất chiếu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>@ViewData["Title"]</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <img src="@Model.ImageUrl" alt="@Model.MovieTitle" class="img-fluid rounded shadow-sm" />
    </div>
    <div class="col-md-8">
        <p><b>Phim:</b> @Model.MovieTitle</p>
        <p><b>Phòng chiếu:</b> @Model.RoomName</p>
        <p><b>Thời gian bắt đầu:</b> @Model.StartTime.ToString("dd/MM/yyyy HH:mm")</p>
        <p><b>Thời gian kết thúc:</b>@Model.EndTime.ToString("dd/MM/yyyy HH:mm")</p>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.ShowTimeId" class="btn btn-warning">Sửa</a>
            <a asp-action="Delete" asp-route-id="@Model.ShowTimeId" class="btn btn-danger">Xóa</a>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </div>
</div>
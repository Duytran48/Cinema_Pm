@model DoanCStar.Models.Promotion

@{
    ViewData["Title"] = "Thêm mới Khuyến mãi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h2 class="mt-4">Thêm mới Khuyến mãi</h2>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-action="Index">Danh sách</a></li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên chương trình</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên khuyến mãi..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Code" class="form-label fw-bold">Mã Khuyến Mãi (Code) *</label>
                            <input asp-for="Code" class="form-control text-uppercase" placeholder="VD: TET2025" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                            <small class="text-muted">Mã này dùng để khách hàng nhập khi thanh toán.</small>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả điều kiện áp dụng..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4 bg-light p-3 rounded">
                        <h6 class="fw-bold mb-3">Thiết lập giảm giá</h6>
                        <div class="mb-3">
                            <label asp-for="DiscountPercent" class="form-label">Phần trăm giảm (%)</label>
                            <div class="input-group">
                                <input asp-for="DiscountPercent" class="form-control" type="number" min="0" max="100" placeholder="Ví dụ: 10, 20..." />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="DiscountPercent" class="text-danger small"></span>
                        </div>

                        <h6 class="fw-bold mb-3 mt-4">Thời gian áp dụng</h6>
                        <div class="mb-3">
                            <label asp-for="StartDate" class="form-label">Ngày bắt đầu</label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="EndDate" class="form-label">Ngày kết thúc</label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch mt-4">
                            <input class="form-check-input" type="checkbox" asp-for="Active" checked style="transform: scale(1.2);">
                            <label class="form-check-label ms-2 fw-bold" asp-for="Active">Kích hoạt ngay</label>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i> Lưu lại</button>
                    <a asp-action="Index" class="btn btn-secondary px-4 ms-2">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
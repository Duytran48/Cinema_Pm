@model DoanCStar.Models.Promotion

@{
    ViewData["Title"] = "Xóa Khuyến mãi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 text-danger">Xác nhận xóa</h2>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-action="Index">Danh sách</a></li>
        <li class="breadcrumb-item active">Xóa</li>
    </ol>

    <div class="alert alert-warning shadow-sm" role="alert">
        <i class="fas fa-exclamation-triangle me-2 display-6 align-middle"></i>
        <span class="align-middle">Bạn có chắc chắn muốn xóa chương trình khuyến mãi này không? Hành động này không thể hoàn tác.</span>
    </div>

    <div class="card mb-4 shadow-sm border-danger">
        <div class="card-header bg-danger text-white fw-bold">
            <i class="fas fa-info-circle me-2"></i>Thông tin chương trình
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <label class="col-sm-3 fw-bold text-end">Tên chương trình:</label>
                <div class="col-sm-9 fs-5 text-primary">@Model.Name</div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-3 fw-bold text-end">Mức giảm giá:</label>
                <div class="col-sm-9 fw-bold text-danger">@Model.DiscountPercent.ToString("N0")%</div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-3 fw-bold text-end">Thời gian áp dụng:</label>
                <div class="col-sm-9">
                    Từ <strong>@Model.StartDate.ToString("dd/MM/yyyy")</strong> đến <strong>@Model.EndDate.ToString("dd/MM/yyyy")</strong>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-3 fw-bold text-end">Mô tả:</label>
                <div class="col-sm-9 text-muted fst-italic">
                    @(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)
                </div>
            </div>

            <hr />
            <form asp-action="Delete" class="text-end">
                <input type="hidden" asp-for="PromotionId" />
                <a asp-action="Index" class="btn btn-secondary px-4 me-2">Hủy bỏ</a>
                <button type="submit" class="btn btn-danger px-4"><i class="fas fa-trash-alt me-2"></i> Xác nhận xóa</button>
            </form>
        </div>
    </div>
</div>
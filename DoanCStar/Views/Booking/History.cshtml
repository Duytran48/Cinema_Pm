@model DoanCStar.ViewModels.HistoryViewModel

@{
    ViewData["Title"] = "Lịch sử giao dịch";
    Layout = "_BookingLayout";
}

<div class="container py-5">
    <h3 class="text-warning mb-4 border-start border-4 border-warning ps-3 text-uppercase fw-bold">Lịch sử giao dịch</h3>

    <ul class="nav nav-pills mb-4" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold text-uppercase px-4" id="pills-movie-tab" data-bs-toggle="pill" data-bs-target="#pills-movie" type="button" role="tab">Vé Phim</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold text-uppercase px-4" id="pills-snack-tab" data-bs-toggle="pill" data-bs-target="#pills-snack" type="button" role="tab">Bắp Nước Online</button>
        </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">

        <div class="tab-pane fade show active" id="pills-movie" role="tabpanel">
            @if (Model.MovieBookings == null || !Model.MovieBookings.Any())
            {
                <div class="alert alert-dark text-center py-4 text-white-50">
                    Bạn chưa có vé phim nào.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Thời gian đặt</th>
                                <th>Phim</th>
                                <th>Rạp / Phòng</th>
                                <th>Suất chiếu</th>
                                <th>Ghế</th>
                                <th>Tổng tiền</th>
                                <th>Thanh toán</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.MovieBookings)
                            {
                                var seatNames = string.Join(", ",
                                b.BookingSeats
                                .OrderBy(bs => bs.Seat.Row)
                                .ThenBy(bs => bs.Seat.Number)
                                .Select(bs => $"{bs.Seat.Row}{bs.Seat.Number}")
                                );

                                <tr>
                                    <td>@b.BookingDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@b.ShowTime.Movie.Title</td>
                                    <td>
                                        @b.ShowTime.Room.Cinema.Name<br />
                                        <small>@b.ShowTime.Room.Name</small>
                                    </td>
                                    <td>@b.ShowTime.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @seatNames
                                        @if (b.BookingConcessions != null && b.BookingConcessions.Any())
                                        {
                                            <div class="small text-info border-top border-secondary pt-1 mt-1">
                                                @foreach (var c in b.BookingConcessions)
                                                {
                                                    <div>+ @c.Quantity x @c.Concession.Name</div>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold text-warning">@b.TotalPrice.ToString("N0") đ</td>
                                    <td>
                                        @if (b.Payment != null)
                                        {
                                            if (b.Payment.Status == "Completed")
                                            {
                                                <span class="badge bg-success">Đã thanh toán</span>
                                            }
                                            else if (b.Payment.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">Đang chờ thanh toán</span>
                                            }
                                            else if (b.Payment.Status == "Failed")
                                            {
                                                <span class="badge bg-danger">Thanh toán thất bại</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@b.Payment.Status</span>
                                            }
                                            <br />
                                            <small>@b.Payment.PaymentMethod</small>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Chưa tạo payment</span>
                                        }
                                    </td>

                                    <td>
                                        <a asp-controller="Booking" asp-action="Complete" asp-route-id="@b.BookingId"
                                           class="btn btn-sm btn-warning">
                                            Xem chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="tab-pane fade" id="pills-snack" role="tabpanel">
            @if (Model.SnackOrders == null || !Model.SnackOrders.Any())
            {
                <div class="alert alert-dark text-center py-5">
                    <i class="bi bi-cup-hot display-4 d-block mb-3 text-muted"></i>
                    <span class="text-white-50 fs-5">Bạn chưa đặt bắp nước online lần nào.</span>
                    <div class="mt-3">
                        <a href="/Snacks/Index" class="btn btn-outline-warning fw-bold">ĐẶT MÓN NGAY</a>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-striped align-middle border-secondary">
                        <thead class="table-secondary text-uppercase small text-muted">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Chi tiết món</th>
                                <th class="text-end">Tổng tiền</th>
                                <th>Thanh toán</th>
                                <th class="text-center">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.SnackOrders)
                            {
                                <tr>
                                    <td class="fw-bold text-info">@s.OrderCode</td>
                                    <td>
                                        @s.OrderDate.ToString("dd/MM/yyyy")<br>
                                        <small class="text-muted">@s.OrderDate.ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        <ul class="list-unstyled mb-0 small">
                                            @foreach (var d in s.SnackOrderDetails)
                                            {
                                                <li class="mb-1">
                                                    <span class="badge bg-secondary me-1">@d.Quantity</span>
                                                    <strong class="text-white">@d.Concession.Name</strong>
                                                </li>
                                            }
                                        </ul>
                                    </td>
                                    <td class="text-end fw-bold text-warning">@s.TotalAmount.ToString("N0") đ</td>
                                    <td><span class="small text-white-50">@s.PaymentMethod</span></td>
                                    <td class="text-center">
                                        @if (s.Status == "Completed")
                                        {
                                            <span class="badge bg-success">Hoàn thành</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">@s.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>
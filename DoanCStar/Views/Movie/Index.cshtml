@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; 
}
@model List<DoanCStar.ViewModels.MovieViewModel>
@{
    ViewData["Title"] = "Quản lý Phim & Suất chiếu";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-success">
        Thêm phim mới
    </a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Chưa có phim nào trong hệ thống.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">Ảnh</th>
                    <th>Tên phim</th>
                    <th>Thể loại</th>
                    <th>Thời lượng</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(m.ImageUrl))
                            {
                                <img src="@m.ImageUrl" width="60" height="60" class="img-thumbnail" style="object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light border rounded d-flex align-items-center justify-content-center" style="width:60px; height:60px;">
                                    <small class="text-muted">No image</small>
                                </div>
                            }
                        </td>
                        <td><strong>@m.Title</strong></td>
                        <td>@m.Genre</td>
                        <td>@m.Duration phút</td>
                        <td>
                            <span class="badge @(m.Status == "Đang chiếu" ? "bg-success" : m.Status == "Sắp chiếu" ? "bg-warning" : "bg-secondary")">
                                @m.Status
                            </span>
                        </td>
                        <td>

                            @* <a asp-action="ShowTime"  class="btn btn-sm btn-info">Xuất chiếu</a> *@

                            <a asp-action="Details" asp-route-id="@m.MovieId" class="btn btn-sm btn-info">Xem</a>
                            <a asp-action="Edit" asp-route-id="@m.MovieId" class="btn btn-sm btn-warning">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@m.MovieId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Xóa phim \" @m.Title\"?');">
                                    Xóa
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
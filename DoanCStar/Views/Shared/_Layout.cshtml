    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    @* === SCRIPT XỬ LÝ FORM ĐĂNG NHẬP VÀ ĐĂNG KÝ === *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // === XỬ LÝ FORM ĐĂNG NHẬP ===
            const loginForm = document.getElementById("loginForm");

            if (loginForm) {
                const loginError = document.getElementById("loginError");
                const loginInputs = loginForm.querySelectorAll("input");
                const loginButton = loginForm.querySelector('button[type="submit"]');

                loginForm.addEventListener("submit", function (e) {
                    e.preventDefault();
                    const formData = new FormData(loginForm);

                    loginButton.disabled = true;
                    loginButton.classList.add("btn-loading");
                    if (loginError) loginError.style.display = 'none';

                    fetch(loginForm.action, {
                        method: "POST",
                        body: new URLSearchParams(formData)
                    })
                    .then(response => {
                        return response.json().then(data => ({ ok: response.ok, data: data }));
                    })
                    .then(result => {
                        if (result.ok) {
                            if (result.data.redirectUrl) {
                                window.location.href = result.data.redirectUrl;
                            } else {
                                window.location.reload();
                            }
                        } else {
                            if (result.data.message) {
                                loginError.textContent = result.data.message;
                                loginError.style.display = "block";
                            }
                            loginButton.disabled = false;
                            loginButton.classList.remove("btn-loading");
                        }
                    })
                    .catch(err => {
                        loginError.textContent = "Không thể kết nối. Vui lòng thử lại.";
                        loginError.style.display = "block";
                        loginButton.disabled = false;
                        loginButton.classList.remove("btn-loading");
                    });
                });

                loginInputs.forEach(input => {
                    input.addEventListener("input", function() {
                        if (loginError.style.display === "block") {
                            loginError.style.display = "none";
                        }
                    });
                });
            }

            // === XỬ LÝ FORM ĐĂNG KÝ ===
            const registerForm = document.getElementById("registerForm");

            if (registerForm) {
                const registerError = document.getElementById("registerError");
                const registerInputs = registerForm.querySelectorAll("input");

                registerForm.addEventListener("submit", function (e) {
                    e.preventDefault();
                    const formData = new FormData(registerForm);

                    fetch(registerForm.action, {
                        method: "POST",
                        body: new URLSearchParams(formData)
                    })
                    .then(response => {
                        return response.json().then(data => ({ ok: response.ok, data: data }));
                    })
                    .then(result => {
                        if (result.ok) {
                            if (result.data.redirectUrl) {
                                window.location.href = result.data.redirectUrl;
                            } else {
                                window.location.reload();
                            }
                        } else {
                            if (result.data.message) {
                                registerError.textContent = result.data.message;
                                registerError.style.display = "block";
                            }
                        }
                    })
                    .catch(err => {
                        registerError.textContent = "Không thể kết nối. Vui lòng thử lại.";
                        registerError.style.display = "block";
                    });
                });

                registerInputs.forEach(input => {
                    input.addEventListener("input", function() {
                        if (registerError.style.display === "block") {
                            registerError.style.display = "none";
                        }
                    });
                });
            }

        });
    </script>
    @* === SCRIPT XỬ LÝ MODAL TRAILER PHIM === *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Lấy tất cả các nút có class 'js-play-trailer'
            const trailerButtons = document.querySelectorAll('.js-play-trailer');
            const trailerModal = new bootstrap.Modal(document.getElementById('trailerModal'));
            const trailerIframe = document.getElementById('trailerIframe');
            const trailerTitle = document.getElementById('trailerModalLabel');
            const modalElement = document.getElementById('trailerModal');

            trailerButtons.forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();

                    const url = this.getAttribute('data-trailer-url');
                    const title = this.getAttribute('data-movie-title');

                    // 2. Hàm lấy YouTube ID từ URL
                    const videoId = getYouTubeId(url);

                    if (videoId) {
                        // 3. Tạo link Embed và thêm autoplay=1 để tự chạy
                        const embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1`;

                        // Gán link vào iframe
                        trailerIframe.src = embedUrl;
                        if(title) trailerTitle.textContent = title;

                        // Hiện modal
                        trailerModal.show();
                    } else {
                        alert("Link trailer không hợp lệ hoặc chưa được cập nhật.");
                    }
                });
            });

            // 4. Khi đóng Modal thì tắt video (xóa src)
            modalElement.addEventListener('hidden.bs.modal', function () {
                trailerIframe.src = "";
            });

            // Hàm phụ trợ: Tách ID video từ link YouTube các kiểu
            function getYouTubeId(url) {
                if (!url) return null;
                const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
                const match = url.match(regExp);
                return (match && match[2].length === 11) ? match[2] : null;
            }
        });
    </script>


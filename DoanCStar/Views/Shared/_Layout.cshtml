    @* === SCRIPT XỬ LÝ TÌM KIẾM PHIM === *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("globalSearch");
            const resultsBox = document.getElementById("searchResults");
            const emptyMsg = document.getElementById("searchEmpty");
            const loadingMsg = document.getElementById("searchLoading");
            let timeout = null;

            searchInput.addEventListener("input", function () {
                const q = this.value.trim();
                clearTimeout(timeout);

                if (q.length < 2) {
                    resultsBox.style.display = "none";
                    return;
                }

                timeout = setTimeout(async () => {
                    loadingMsg.style.display = "block";
                    emptyMsg.style.display = "none";
                    resultsBox.style.display = "block";
                    resultsBox.innerHTML = '<div id="searchLoading" class="p-3 text-center text-warning"><i class="bi bi-hourglass-split"></i> Đang tìm...</div>';

                    try {
                        const res = await fetch(`/Search/Suggestions?q=${encodeURIComponent(q)}`);
                        const data = await res.json();

                        resultsBox.innerHTML = "";

                        if (data.movies.length === 0 && data.cinemas.length === 0) {
                            resultsBox.innerHTML = '<div class="p-3 text-center text-muted">Không tìm thấy kết quả nào</div>';
                            return;
                        }

                        // Phim
                        data.movies.forEach(m => {
                            const div = document.createElement("a");
                            div.href = m.url;
                            div.className = "d-flex align-items-center search-result-item text-white text-decoration-none";
                            div.innerHTML = `
                                <img src="${m.image}" class="search-movie-img me-3" onerror="this.src='/images/no-image.jpg'">
                                <div>
                                    <strong>${m.title}</strong><br>
                                    <small class="text-warning"><i class="bi bi-film"></i> Phim</small>
                                </div>
                            `;
                            resultsBox.appendChild(div);
                        });

                        // Rạp
                        data.cinemas.forEach(c => {
                            const div = document.createElement("a");
                            div.href = c.url;
                            div.className = "d-block search-result-item text-white text-decoration-none";
                            div.innerHTML = `
                                <strong>${c.name}</strong> - ${c.city}<br>
                                <small class="text-success"><i class="bi bi-geo-alt-fill"></i> Rạp chiếu</small>
                            `;
                            resultsBox.appendChild(div);
                        });

                    } catch (err) {
                        resultsBox.innerHTML = '<div class="p-3 text-center text-danger">Lỗi kết nối</div>';
                    }
                }, 300);
            });

            // Ẩn khi click ra ngoài
            document.addEventListener("click", function (e) {
                if (!searchInput.contains(e.target) && !resultsBox.contains(e.target)) {
                    resultsBox.style.display = "none";
                }
            });
        });
    </script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</body>
</html>
@* File: Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống bán vé rẻ , hiện đại bậc nhất</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" aaaa/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <partial name="_PageStyles" />

</head>
<body>
    <header>
        <div class="container d-flex align-items-center justify-content-between">
            <a class="navbar-brand" href="/">
                <img src="/images/CN_Logo.png" alt="CineStar" />
            </a>

            <div class="d-flex gap-2">
                <a asp-controller="Home"
                   asp-action="Booking"
                   class="btn btn-animate btn-ticket">
                    <i class="bi bi-ticket-perforated"></i> ĐẶT VÉ NGAY
                </a>
                <a class="btn btn-animate btn-snack" asp-controller="Snacks" asp-action="Index" style="text-decoration: none; display: flex; align-items: center;">
                    <i class="bi bi-cup-hot me-1"></i> ĐẶT BẮP NƯỚC
                </a>

            </div>
            @* Nút đăng nhập / Xin chào *@
            <div class="d-flex align-items-center gap-3">
                <div class="position-relative search-container">
                    <input type="text"
                           id="globalSearch"
                           class="search-bar form-control"
                           placeholder="Tìm phim, rạp..."
                           autocomplete="off" />

                    <!-- Dropdown gợi ý -->
                    <div id="searchResults"
                         class="position-absolute top-100 start-0 end-0 bg-dark border border-warning shadow-lg mt-1 rounded-3 overflow-hidden"
                         style="z-index: 9999; max-height: 70vh; overflow-y: auto; display: none;">

                        <div class="p-3 text-center text-muted" id="searchEmpty" style="display:none;">
                            Không tìm thấy kết quả nào
                        </div>

                        <div id="searchLoading" class="p-3 text-center text-warning" style="display:none;">
                            <i class="bi bi-hourglass-split"></i> Đang tìm...
                        </div>
                    </div>
                </div>                @if (User.Identity.IsAuthenticated)
                {

                    <div class="dropdown user-dropdown">

                        <a href="#" class="user-trigger d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle me-1"></i>
                            Xin chào, @User.Identity.Name
                        </a>

                        <ul class="dropdown-menu user-dropdown-menu">
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-person me-2"></i>
                                    Thông tin cá nhân
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                                else
                {
                    @* NẾU CHƯA ĐĂNG NHẬP: Hiển thị nút "Đăng nhập" (mở Modal) *@
                    <a href="#" class="text-white text-decoration-none" data-bs-toggle="modal" data-bs-target="#authModal">
                        <i class="bi bi-person-circle"></i> Đăng nhập
                    </a>
                }
                <div class="lang-switch">
                    <div class="lang-trigger d-flex align-items-center text-white text-decoration-none">
                        <img src="https://flagcdn.com/w20/vn.png" alt="VN" class="lang-flag me-1" />
                        <span>VN</span>
                        <i class="ms-1 bi bi-caret-down-fill"></i>
                    </div>
                    <ul class="lang-dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="#">
                                <img src="https://flagcdn.com/w20/gb.png" alt="EN" class="lang-flag me-1" />
                                English
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="subnav container">
            <div class="subnav-left">
                @* KHỐI DROPDOWN "CHỌN RẠP" *@
                <div class="dropdown cinema-dropdown">
                    <a href="#" class="subnav-link dropdown-toggle" role="button">
                        <i class="bi bi-geo-alt"></i> Chọn rạp
                    </a>
                    <div class="dropdown-menu cinema-dropdown-menu shadow">
                        @await Component.InvokeAsync("CinemaList")
                    </div>
                </div>
                @* LINK "LỊCH CHIẾU" *@
                <a asp-controller="Schedule" asp-action="Index" class="subnav-link">
                    <i class="bi bi-calendar-week"></i> Lịch chiếu
                </a>
            </div>
            <div class="subnav-right">
                <a href="#" class="subnav-link">Khuyến mãi</a>
                <a href="#" class="subnav-link">Tổ chức sự kiện</a>
                <a href="#" class="subnav-link">Dịch vụ giải trí khác</a>
                <a href="#" class="subnav-link">Giới thiệu</a>
            </div>
        </div>
    </header>

    <div class="container my-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Modal đăng nhập/đăng ký *@
    <div class="modal fade" id="authModal" tabindex="-1" aria-labelledby="authModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <ul class="nav nav-tabs" id="authTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="login-tab" data-bs-toggle="tab" data-bs-target="#login-pane" type="button" role="tab" aria-controls="login-pane" aria-selected="true">
                                Đăng nhập
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="register-tab" data-bs-toggle="tab" data-bs-target="#register-pane" type="button" role="tab" aria-controls="register-pane" aria-selected="false">
                                Đăng ký
                            </button>
                        </li>
                    </ul>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="tab-content" id="authTabsContent">
                        @* Phần đăng nhập *@
                        <div class="tab-pane fade show active" id="login-pane" role="tabpanel" aria-labelledby="login-tab">
                            <div id="loginError" class="alert alert-danger" role="alert" style="display: none;">
                            </div>
                            <form id="loginForm" asp-controller="Account" asp-action="Login" method="post">
                                <div class="mb-3">
                                    <label for="loginIdentifier" class="form-label">Email, SĐT, hoặc Tên đăng nhập</label>
                                    <input type="text" class="form-control" id="loginIdentifier" name="Identifier" required>
                                </div>
                                <div class="mb-3">
                                    <label for="loginPassword" class="form-label">Mật khẩu</label>
                                    <input type="password" class="form-control" id="loginPassword" name="Password" required>
                                </div>
                                <div class="mb-3 form-check">
                                    <input type="checkbox" class="form-check-input" id="rememberMe" name="RememberMe" value="true">
                                    <label class="form-check-label" for="rememberMe">Ghi nhớ tôi</label>
                                </div>
                                <button type="submit" class="btn btn-warning w-100 fw-bold">
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display: none;"></span>
                                    <span class="button-text">ĐĂNG NHẬP</span>
                                </button>
                                <div class="text-center mt-3">
                                    <a href="#" class="text-warning text-decoration-none">Quên mật khẩu?</a>
                                </div>
                            </form>
                        </div>

                        @* Phần đăng ký *@
                        <div class="tab-pane fade" id="register-pane" role="tabpanel" aria-labelledby="register-tab">
                            <div id="registerError" class="alert alert-danger" role="alert" style="display: none;">
                            </div>
                            <form id="registerForm" asp-controller="Account" asp-action="Register" method="post">
                                <div class="mb-3">
                                    <label for="registerName" class="form-label">Họ và tên</label>
                                    <input type="text" class="form-control" id="registerName" name="FullName" required>
                                </div>
                                <div class="mb-3">
                                    <label for="registerEmail" class="form-label">Email</label>
                                    <input type="email" class="form-control" id="registerEmail" name="Email" required>
                                </div>
                                <div class="mb-3">
                                    <label for="registerPhone" class="form-label">Số điện thoại</label>
                                    <input type="tel" class="form-control" id="registerPhone" name="Phone" required>
                                </div>
                                <div class="mb-3">
                                    <label for="registerPassword" class="form-label">Mật khẩu</label>
                                    <input type="password" class="form-control" id="registerPassword" name="Password" required>
                                </div>
                                <div class="mb-3">
                                    <label for="confirmPassword" class="form-label">Xác nhận mật khẩu</label>
                                    <input type="password" class="form-control" id="confirmPassword" name="ConfirmPassword" required>
                                </div>
                                <button type="submit" class="btn btn-warning w-100 fw-bold">ĐĂNG KÝ</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


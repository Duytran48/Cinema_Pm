@using DoanCStar.Models
@model IEnumerable<Movie>

@{
   
    var sectionTitle = ViewBag.SectionTitle ?? "PHIM SẮP CHIẾU";
    var statusValue = ViewBag.StatusValue ?? "Sắp chiếu";  
}

<div class="container my-5 coming-soon-section">
    <div class="d-flex justify-content-center align-items-center mb-3">
        <h4 class="fw-bold text-warning">PHIM SẮP CHIẾU</h4>
    </div>

    <div class="swiper coming-soon-swiper">
        <div class="swiper-wrapper">

            @if (Model != null && Model.Any())
            {
                @foreach (var movie in Model)
                {
                    <div class="swiper-slide">

                      
                        <a asp-controller="Home" asp-action="MovieDetails" asp-route-id="@movie.MovieId" class="movie-poster-box">
                            <img src="@movie.ImageUrl" class="img-fluid" alt="@movie.Title" />

                            <div class="movie-info-overlay">
                                <ul class="movie-info-list">
                                    <li><i class="bi bi-tag-fill"></i> <span>@movie.Genre</span></li>
                                    <li><i class="bi bi-clock-fill"></i> <span>@movie.Duration phút</span></li>
                                    <li><i class="bi bi-globe"></i> <span>@movie.Country</span></li>
                                    <li><i class="bi bi-chat-left-dots-fill"></i> <span>@movie.Language</span></li>
                                </ul>
                            </div>
                        </a>

                        <div class="text-center mt-2">
                            <h6 class="fw-bold text-white mb-4">@movie.Title</h6>
                            <div class="card-buttons">
                                
                                <a href="javascript:void(0);"
                                   class="btn btn-sm btn-outline-warning js-play-trailer"
                                   data-trailer-url="@movie.TrailerUrl"
                                   data-movie-title="@movie.Title">
                                    Xem trailer
                                </a>

                               
                                <a asp-controller="Home"
                                   asp-action="MovieDetails"
                                   asp-route-id="@movie.MovieId"
                                   class="btn btn-sm btn-outline-warning">
                                    Tìm hiểu thêm
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p class="text-center text-white-50">Hiện chưa có phim sắp chiếu.</p>
                </div>
            }

        </div>

        <div class="swiper-button-prev coming-soon-prev"></div>
        <div class="swiper-button-next coming-soon-next"></div>
        <div class="swiper-pagination coming-soon-pagination"></div>
    </div>

  
    <div class="text-center mt-4">
        <a asp-controller="Home"
           asp-action="Movies"
           asp-route-status="@statusValue"
           class="btn btn-outline-warning fw-bold px-5 py-2">
            XEM THÊM
        </a>
    </div>
</div>